# Copy this file to ".env" and fill in your Firebase Realtime Database details.
# Online mode is disabled until these are set. Offline mode works without them.
#
# Get these from the Firebase console:
#   Project settings -> General -> Your apps -> Web app -> SDK setup & config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
